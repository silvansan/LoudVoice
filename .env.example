# ─── LiveKit ────────────────────────────────────────────────────────────────────
# Your API key — any string you choose
LIVEKIT_API_KEY=my-app-key

# Your API secret — MUST be at least 32 characters
# Generate one with: openssl rand -hex 32
LIVEKIT_API_SECRET=replace-this-with-a-32-char-secret-minimum

# ─── URLs ───────────────────────────────────────────────────────────────────────
# Public WebSocket URL — what browsers on the internet use to reach LiveKit
# Must match your reverse proxy / subdomain for LiveKit
PUBLIC_LIVEKIT_WSS=wss://livekit.example.com

# LAN WebSocket URL — what browsers on your local network use
# Replace with your server's actual LAN IP
LOCAL_LIVEKIT_WSS=ws://192.168.1.x:7880

# ─── Security ───────────────────────────────────────────────────────────────────
# Password for the /admin page
ADMIN_PASSWORD=change-this-admin-password

# Token required in the URL to access the web interface
# Share URLs as: https://voice.example.com/?token=ACCESS_TOKEN
ACCESS_TOKEN=change-this-access-token
