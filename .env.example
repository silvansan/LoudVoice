# =========================================
# UnderSound Environment Configuration
# =========================================

# ---------- LiveKit ----------
LIVEKIT_API_KEY=linguacast
LIVEKIT_API_SECRET=change_this_secret_to_32_chars_minimum

# Public WebSocket URL used by browsers
PUBLIC_LIVEKIT_WSS=wss://livekit.example.com

# Internal Docker network URL
LOCAL_LIVEKIT_WSS=ws://livekit:7880

# Internal API URL
INTERNAL_LIVEKIT_URL=http://livekit:7880

# ---------- Website ----------
LINK_BASE_URL=https://voice.example.com

# ---------- Admin ----------
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change_this_password

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password

# ---------- Access Tokens ----------
ACCESS_TOKEN=change_this_access_token
ADMIN_ACCESS_TOKEN=change_this_admin_token
SPEAKER_TOKEN=change_this_speaker_token
LISTENER_TOKEN=change_this_listener_token

# ---------- Storage ----------
DATA_PATH=/app/data/app-data.json
UPLOAD_ROOT=/app/uploads

# ---------- Node ----------
NODE_ENV=production
PORT=8080
