# LiveKit
LIVEKIT_API_KEY=my-app-key
LIVEKIT_API_SECRET=replace-this-with-a-32-char-secret-minimum

# Browser-facing LiveKit URLs
# Use wss://livekit.example.com behind HTTPS on a domain.
PUBLIC_LIVEKIT_WSS=wss://livekit.example.com

# Used only when the browser opens the web app on localhost/127.0.0.1.
LOCAL_LIVEKIT_WSS=ws:/livekit:7880

# Initial login seed
# On first boot, the app creates this admin user if no data file exists yet.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-this-admin-password

# Backward-compatible fallback for the initial admin login.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password

# Optional: force generated speaker/listener links and QR codes to use this base URL.
# If empty, links use the host/domain used to open the admin panel.
LINK_BASE_URL=

# Optional persistence paths inside the web container.
DATA_PATH=/app/data/app-data.json
UPLOAD_ROOT=/app/uploads
